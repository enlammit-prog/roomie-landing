# Endpoints de Formspree (https://formspree.io) para los formularios de
# "Coordinar videollamada" y "Sumate a la lista". Sin estas variables, los
# formularios muestran un error y no envían nada.
NEXT_PUBLIC_VIDEOCALL_FORM_ENDPOINT=https://formspree.io/f/TU_ID_VIDEOLLAMADA
NEXT_PUBLIC_WAITLIST_FORM_ENDPOINT=https://formspree.io/f/TU_ID_WAITLIST
