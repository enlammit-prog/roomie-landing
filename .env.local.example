# Endpoint de Formspree (https://formspree.io) para el formulario "Sumate a
# la lista". Sin esta variable, el formulario muestra un error y no envía nada.
NEXT_PUBLIC_WAITLIST_FORM_ENDPOINT=https://formspree.io/f/TU_ID_WAITLIST

# Link para reservar videollamada (todos los botones "Coordinar videollamada" /
# "Book a call"). Opcional: sin esta variable, usa el link de Google Calendar
# por defecto definido en src/lib/links.ts.
NEXT_PUBLIC_BOOKING_URL=https://calendar.app.google/rzkTFUEhQp9EWs4N6
